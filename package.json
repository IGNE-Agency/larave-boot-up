{
  "scripts": {
    "format": "npm run format:php && npm run format:prettier",
    "format:php": "./vendor/bin/pint",
    "format:prettier": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.php": [
      "./vendor/bin/pint"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1"
  }
}
